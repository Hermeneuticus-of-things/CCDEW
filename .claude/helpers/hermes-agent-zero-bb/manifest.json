{
  "manifest_version": 2,
  "name": "Hermes Voice",
  "version": "2.0",
  "description": "Hermes voice alerts for urgent emails",
  "author": "CCDEW",
  "homepage_url": "https://github.com/ccdew/hermes",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png"
  },
  "browser_action": {
    "default_title": "Hermes Voice",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": [
    "storage",
    "tabs"
  ]
}
