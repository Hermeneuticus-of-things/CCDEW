{
  "manifest_version": 2,
  "name": "CCDEW Email Intelligence",
  "version": "3.0.2",
  "description": "La deschiderea Betterbird — vezi direct alertele de impact. Click pe alertă = deschide emailul.",
  "applications": {
    "gecko": {
      "id": "ccdew-email-intelligence@ccdew",
      "strict_min_version": "115.0"
    }
  },
  "icons": {
    "16": "icons/ccdew-16.png",
    "32": "icons/ccdew-32.png",
    "48": "icons/ccdew-48.png",
    "96": "icons/ccdew-96.png"
  },
  "permissions": [
    "tabs",
    "accountsRead",
    "messagesRead",
    "messagesUpdate",
    "http://localhost:8766/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_icon": {
      "16": "icons/ccdew-16.png",
      "32": "icons/ccdew-32.png"
    },
    "default_title": "CCDEW Impact Alerts",
    "default_area": "maintoolbar"
  }
}
